rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function estaLogado() {
      return request.auth != null;
    }

    function dadosUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function ehAdmin() {
      return estaLogado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && dadosUsuario().perfil == "admin"
        && dadosUsuario().ativo == true;
    }

    function ehDono(uid) {
      return estaLogado() && request.auth.uid == uid;
    }

    function ehDonoSolicitacao() {
      return estaLogado()
        && resource.data.usuarioUid == request.auth.uid;
    }

    function ehDonoNovaSolicitacao() {
      return estaLogado()
        && request.resource.data.usuarioUid == request.auth.uid;
    }

    match /usuarios/{uid} {
      allow read: if ehDono(uid) || ehAdmin();
      allow create, update, delete: if ehAdmin();
    }

    match /materiais/{materialId} {
      allow read: if estaLogado();
      allow create, update, delete: if ehAdmin();
    }

    match /solicitacoes/{solicitacaoId} {
      allow create: if ehDonoNovaSolicitacao();

      allow read: if ehAdmin() || ehDonoSolicitacao();

      allow update, delete: if ehAdmin();
    }

    match /vinculosRequisicoes/{vinculoId} {
      allow read: if ehAdmin();
      allow create, update, delete: if ehAdmin();
    }

    match /requisicoesPorGlpi/{glpiId} {
      allow read: if ehAdmin();
      allow create, update, delete: if ehAdmin();
    }

    match /resumosAdmin/{resumoId} {
      allow read: if ehAdmin();
      allow create, update, delete: if ehAdmin();
    }

    match /configuracoes/{document=**} {
      allow read, write: if ehAdmin();
    }

    match /importacoes/{document=**} {
      allow read, write: if ehAdmin();
    }
  }
}
